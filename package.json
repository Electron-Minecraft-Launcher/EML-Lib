{
  "name": "eml-lib",
  "version": "2.1.0",
  "description": "Create your Electron Minecraft Launcher easily!",
  "author": "GoldFrite",
  "license": "MIT",
  "main": "index.js",
  "types": "index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "tsx test/test.ts",
    "test-electron": "npm run build && electron dist/test/test.js",
    "release": "node .github/release.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Electron-Minecraft-Launcher/EML-Lib.git"
  },
