    "electron",
    "nodejs",
    "minecraft",
    "forge",
    "launcher",
    "mods"
  ],
  "bugs": {
    "url": "https://github.com/Electron-Minecraft-Launcher/EML-Lib/issues"
  },
  "homepage": "https://github.com/Electron-Minecraft-Launcher/EML-Lib#readme",
  "dependencies": {
    "tslib": "^2.8.1",
    "yauzl": "^3.2.1",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^3.3.0",
    "electron": "^41.1.0",
    "electron-updater": "^6.8.3",
    "prettier": "^3.3.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    },
    "electron-updater": {
      "optional": true
    }
