{
  "compilerOptions": {
    "target": "es2021",
    "importHelpers": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "./dist",
    "sourceMap": true,
  },
  "exclude": [
    "dist/"
  ]
}